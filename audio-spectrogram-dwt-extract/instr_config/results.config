#DOC: Receiver da nhan file stego.wav tu sender
audio_received = receiver:other_users/ubuntu/.local/result/spectrogram_dwt_extract_check.txt : CONTAINS : PASS_AUDIO_RECEIVED
#DOC: Receiver da nhan file secret.key tu sender
key_received = receiver:other_users/ubuntu/.local/result/spectrogram_dwt_extract_check.txt : CONTAINS : PASS_KEY_RECEIVED
#DOC: Da tach tin hieu bi mat tu he so tan so cao cua DWT
dwt_signal_extracted = receiver:other_users/ubuntu/.local/result/spectrogram_dwt_extract_check.txt : CONTAINS : PASS_DWT_SIGNAL_EXTRACTED
#DOC: Da dung key de dao hoan vi anh bi mat
key_permutation_used = receiver:other_users/ubuntu/.local/result/spectrogram_dwt_extract_check.txt : CONTAINS : PASS_KEY_PERMUTATION_USED
#DOC: Da tao file anh recovered_secret.png
secret_image_recovered = receiver:other_users/ubuntu/.local/result/spectrogram_dwt_extract_check.txt : CONTAINS : PASS_SECRET_IMAGE_RECOVERED
#DOC: Da mo truc tiep recovered_secret.png de quan sat
recovered_image_viewed = receiver:other_users/ubuntu/.local/result/spectrogram_dwt_extract_check.txt : CONTAINS : PASS_RECOVERED_IMAGE_VIEWED
#DOC: Anh recovered_secret.png dung voi anh bi mat ban dau
recovered_image_valid = receiver:other_users/ubuntu/.local/result/spectrogram_dwt_extract_check.txt : CONTAINS : PASS_RECOVERED_IMAGE_VALID
